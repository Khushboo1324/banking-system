# ─────────────────────────────────────────────────────────────────────────────
# Backend environment variables
# Copy this file to .env and source it before running the JAR, OR set these
# as environment variables in your deployment platform (Railway, Render, etc.)
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection URI
# Example: MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGODB_URI=mongodb://localhost:27017/banking_db

# Gmail SMTP credentials (use an App Password, not your account password)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# JWT secret — use a long random string in production (at least 64 characters)
JWT_SECRET=replace-me-with-a-long-random-secret-key

# Allowed frontend origin for CORS (used in production)
# Example: ALLOWED_ORIGIN=https://mybank.vercel.app
ALLOWED_ORIGIN=https://banking-system-jpa3.vercel.app
