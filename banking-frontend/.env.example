# ─────────────────────────────────────────────────────────────────────────────
# Frontend environment variables
# Copy this file to .env.local for local overrides, or set these variables in
# your deployment platform (Vercel, Netlify, Render, etc.)
# ─────────────────────────────────────────────────────────────────────────────

# Backend API origin — leave empty to use the same origin (Vite proxy in dev,
# or a same-host/same-port deployment in production).
# Example: VITE_API_BASE_URL=https://api.mybank.com
VITE_API_BASE_URL=
